# ============================================================================
# CONFIGURACIÓN DE SEGURIDAD - OpenClaw + Agentes Ejecutivos
# ============================================================================
# ⚠️ IMPORTANTE: NUNCA comitear valores reales a Git
# Copiar a .env.security y llenar con valores reales
# ============================================================================

# 1. AUTENTICACIÓN & JWT
# ============================================================================
JWT_SECRET_KEY=tu-clave-secreta-super-larga-aleatorio-mínimo-64-caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# 2. ENCRIPTACIÓN
# ============================================================================
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CIPHER_KEY=tu-cipher-key-generado-con-fernet
ENCRYPTION_KEY=tu-encryption-key-para-datos-en-reposo
ENCRYPTION_VERSION=v1

# 3. CREDENCIALES DE MODELOS IA
# ============================================================================
# Claude API
CLAUDE_API_KEY=sk-ant-xxxxx

# OpenClaw con múltiples modelos
OPENAI_API_KEY=sk-proj-xxxxx
GOOGLE_GEMINI_API_KEY=AIzaSyDxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Seleccionar modelo primario
PRIMARY_MODEL=claude-3-5-sonnet

# 4. INTEGRACIÓN CON PLATAFORMAS
# ============================================================================
# Slack
SLACK_BOT_TOKEN=xoxb-xxxxx
SLACK_SIGNING_SECRET=xxxxx
SLACK_WORKSPACE_ID=T0xxxxxx

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password-generado
SMTP_FROM_EMAIL=tu-email@gmail.com

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=xxxxx:xxxxx

# 5. BASE DE DATOS
# ============================================================================
DATABASE_URL=sqlite:///./infraestructura/db/agentes.db?check_same_thread=False

# Passphrase para SQLite encriptado
# Generar con: openssl rand -base64 32
SQLITE_PASSPHRASE=tu-passphrase-super-segura

# 6. JARVISZ DATA WAREHOUSE
# ============================================================================
JARVISZ_DB_PATH=./infraestructura/db/jarvisz.db
JARVISZ_ENCRYPTION=true

# 7. RATE LIMITING
# ============================================================================
RATE_LIMIT_REQUESTS_PER_HOUR=100
RATE_LIMIT_HEARTBEAT_PER_HOUR=10
RATE_LIMIT_SKILL_PER_HOUR=50

# 8. HUMAN-IN-THE-LOOP
# ============================================================================
# Acciones que requieren aprobación manual
APPROVAL_REQUIRED_ACTIONS=send_email,create_file,call_external_api,delete_data

# Timeout para aprobación (segundos)
APPROVAL_TIMEOUT_SECONDS=900

# Canal Slack para aprobaciones
APPROVAL_SLACK_CHANNEL=#approvals

# 9. SEGURIDAD DE AGENTES
# ============================================================================
# Máximo tiempo de ejecución por agente (segundos)
AGENT_MAX_EXECUTION_TIME=300

# Máxima memoria por agente (MB)
AGENT_MAX_MEMORY_MB=512

# Máximas llamadas a API por agente
AGENT_MAX_API_CALLS=10

# Máxima longitud de prompt
MAX_PROMPT_LENGTH=5000

# Máxima longitud de contexto
MAX_CONTEXT_LENGTH=20000

# 10. LOGGING & AUDITORÍA
# ============================================================================
LOG_LEVEL=INFO
SECURITY_LOG_FILE=./logs/security_audit.jsonl
SECURITY_LOG_RETENTION_DAYS=90

# 11. ROLES & PERMISOS
# ============================================================================
# Usuarios con acceso (en producción, usar base de datos)
# Formato: user_id:role:email
AUTHORIZED_USERS=admin:admin:admin@example.com,operator:operator:operator@example.com

# 12. MONITOREO & ALERTAS
# ============================================================================
# Webhook para alertas críticas
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# Email para alertas críticas
ALERT_EMAIL=security@example.com

# 13. BACKUP & DISASTER RECOVERY
# ============================================================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_PATH=./backups/
BACKUP_RETENTION_DAYS=30

# Backup encriptado
BACKUP_ENCRYPTION=true

# 14. COMPLIANCE
# ============================================================================
GDPR_ENABLED=true
SOC2_ENABLED=true

# Data retention policy (días)
DATA_RETENTION_DAYS=365

# 15. AMBIENTE
# ============================================================================
ENVIRONMENT=production
DEBUG=False

# API
API_HOST=127.0.0.1
API_PORT=8000
API_SSL=true
API_SSL_CERT_PATH=/etc/ssl/certs/api-cert.pem
API_SSL_KEY_PATH=/etc/ssl/private/api-key.pem

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. NUNCA comitear valores reales
#    git rm --cached .env.security
#    echo ".env.security" >> .gitignore
#
# 2. Usar en local:
#    cp .env.security.example .env.security
#    # Editar con valores reales
#    # source .env.security (antes de correr)
#
# 3. En producción:
#    - Usar secrets manager (AWS Secrets, HashiCorp Vault, etc)
#    - Nunca en archivos
#    - Rotation cada 90 días
#
# 4. Generar claves seguras:
#    # JWT Secret
#    python -c "import secrets; print(secrets.token_urlsafe(64))"
#
#    # Cipher Key
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
#    # Passphrase
#    openssl rand -base64 32
#
# 5. Validar configuración:
#    python infraestructura/security/validator.py
#
# ============================================================================
